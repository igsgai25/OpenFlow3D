# OpenFlow3D Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://openflow3d:openflow3d@localhost:5432/openflow3d

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── InfluxDB ────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=openflow3d-dev-token
INFLUXDB_ORG=openflow3d
INFLUXDB_BUCKET=sensor_data

# ─── MQTT (Digital Twin) ────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=openflow3d/sensors/

# ─── Sentry Error Tracking ──────────────────────
SENTRY_DSN=

# ─── MLflow Model Registry ─────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── OpenFOAM Docker ───────────────────────────
OPENFOAM_DOCKER_IMAGE=openfoam/openfoam:v12
SOLVER_TIMEOUT_SECONDS=1800
SOLVER_MAX_CORES=4
