{
  "name": "openflow3d",
  "version": "0.1.0",
  "private": true,
  "description": "OpenFlow3D — Open-Source Web-Based CAE Platform for Injection Molding Simulation with PINN Acceleration",
  "author": "OpenFlow3D Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openflow3d/openflow3d.git"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && echo 'FastAPI server: use uvicorn'",
    "build": "cd client && npm run build",
    "lint": "concurrently \"npm run lint:client\" \"npm run lint:server\"",
    "lint:client": "cd client && npx eslint src/",
    "lint:server": "cd server && python -m flake8 .",
    "test": "concurrently \"npm run test:client\" \"npm run test:server\"",
    "test:client": "cd client && npx vitest run",
    "test:server": "cd server && python -m pytest tests/ -v --cov"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
